# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
worktrees/
results/
queue/

# Agent prompt files (generated per-session by launchers)
CLAUDE.md
AGENTS.md

# Experimental code/artifacts
dev/

# Results and trade log files
results.tsv
trades.tsv

# Harness upgrade reflections (per-worktree, untracked like results.tsv)
harness_upgrade.md

# Test logs
*.log

# Environment variables
.env

# Live session logs (real trading data, not committed)
sessions/

# Parquet data files (large, not committed)
data/*.parquet
data/historical/*.parquet
data/realtime/*.parquet

# Agent format-patch archives (stored in .agents/ but not committed)
.agents/*.patch
trades.tsv

# SMT v2 regression outputs (baselines are local, not committed)
data/regression/*/

# SMT v2 runtime state files (ephemeral, not committed)
data/*.json

# Local regression notes
regression.md
